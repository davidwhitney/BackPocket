{
  "name": "pockt",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run vite\"",
    "dev:azure": "swa start http://localhost:5173 --run \"npm run vite\" --api-location api",
    "vite": "vite",
    "server:dev": "tsx watch --env-file=.env server.ts",
    "server": "tsx --env-file=.env server.ts",
    "build": "vite build && npm run build:api",
    "build:api": "cd api && npm install && npm run build",
    "preview": "npm run server",
    "start": "npm run build && npm run server"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "dompurify": "^3.3.3",
    "hono": "^4.7.0",
    "idb": "^8.0.3",
    "jsdom": "^26.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "workbox-cacheable-response": "^7.3.0",
    "workbox-core": "^7.3.0",
    "workbox-expiration": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
